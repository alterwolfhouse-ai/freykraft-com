# Public site configuration
NEXT_PUBLIC_SITE_URL=https://freykraft.com
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_PINTEREST_URL=

# Email capture provider
# In production, set this to a provider endpoint or automation webhook that accepts JSON:
# { email, source, consent, optedInAt, utm }
EMAIL_CAPTURE_WEBHOOK_URL=
EMAIL_CAPTURE_WEBHOOK_SECRET=

# Local production-preview only. Keep empty in deployed production.
EMAIL_CAPTURE_ALLOW_LOCAL_STORE=

# Database placeholder for Phase 0 schema and future Prisma migrations
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/freykraft
